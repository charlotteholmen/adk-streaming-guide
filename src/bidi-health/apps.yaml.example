# Generic bidi-health app config.
#
# At deploy time, copy this to apps.yaml and edit. Each app entry produces two
# probe routes:
#   GET /check/{name}/live         text probe
#   GET /check/{name}/live/audio   audio probe (TTS-synthesized PCM input)
#
# All targets must follow the ADK bidi-demo protocol:
#   WebSocket path: /ws/{user_id}/{session_id}
#   Text frame:     {"type":"text","text":"..."}
#   Audio frame:    raw 16kHz 16-bit PCM mono binary
#   Events:         ADK Event JSON (camelCase via by_alias=True)

defaults:
  text_timeout_seconds: 20
  audio_timeout_seconds: 30
  tts_voice:
    language_code: en-US
    ssml_gender: NEUTRAL  # one of: NEUTRAL, MALE, FEMALE

apps:
  - name: bidi-demo-prod
    ws_url: wss://bidi-demo-761793285222.us-east1.run.app
    query: "What time is it in Tokyo?"

  # Audio-only app (text input is silently dropped server-side).
  # Sends a setup JSON frame before audio. Selects language pair via URL query.
  - name: adk-live-translator-prod
    ws_url: wss://live-translation-761793285222.us-central1.run.app
    ws_query_params:
      source: en
      target: ja
    setup_message: '{"glossary":[]}'
    text_probe_enabled: false
    query: "What time is it in Tokyo?"
    # Audio of "What time is it in Tokyo?" is translated to Japanese; expect
    # "東京" in outputTranscription. Set the Cloud Monitoring matcher to "東京".

  # Hotel concierge app — same protocol as bidi-demo, no extra knobs.
  # Pick a query whose response reliably contains a hotel-specific keyword
  # to use as the Cloud Monitoring matcher (e.g. "Las Vegas").
  - name: grounding-demo-prod
    ws_url: wss://grounding-demo-761793285222.us-east1.run.app
    query: "Where is your hotel?"

  # Example with optional overrides:
  # - name: other-bidi-app
  #   ws_url: wss://other.example.com
  #   query: "What's the weather in Paris?"
  #   audio_query: "Tell me the weather in Paris"  # separate audio phrase
  #   text_timeout_seconds: 30                      # per-app timeout override
